# Polymarket Credentials
PRIVATE_KEY=0x...your_private_key_here
SAFE_ADDRESS=0x...your_safe_address_from_polymarket_settings

# Polymarket API Credentials (generated by scripts/setup_credentials.py)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Signature type: 0=EOA, 1=Poly Proxy, 2=Gnosis Safe
SIGNATURE_TYPE=0

# Chain
CHAIN_ID=137

# Optional: Proxy (if Cloudflare blocks datacenter IPs)
# HTTP_PROXY=http://user:pass@proxy:port

# Optional: Telegram alerts
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
